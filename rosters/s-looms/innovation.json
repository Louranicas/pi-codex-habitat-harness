{
  "schema": "codex-harness.s-loom-module.v1",
  "profile": "innovation",
  "id": "s-innovation",
  "version": "1.0.0",
  "sphere": "meso",
  "purpose": "Generate orthogonal options while retaining evidence, falsification, and measured selection.",
  "activationSignals": ["innovation", "options", "alternative", "explore"],
  "lobeSeat": "option-generator",
  "compatibleWith": ["review", "build", "debug", "architecture", "harness", "observe"],
  "ports": { "accepts": ["objective", "measured_center", "constraint_seal", "cache_reference"], "emits": ["candidate_seal", "falsification_seal", "experiment_contract", "cache_reference"], "barrier": "outside_context_judge" },
  "cache": { "family": "s_loom_innovation", "admission": "causal", "invalidation": "content_sha", "maxEntries": 128 },
  "roles": [
    {
      "id": "baseline-analyst", "title": "measured baseline analyst", "mission": "Establish current behavior, constraints, and the metric an alternative must improve.", "evidenceContract": ["baseline", "constraint", "success measure"],
      "persona": { "defaultPersona": "fleet-scientist", "compatibleRoles": ["researcher", "librarian"], "allowedPermissionClasses": ["design_read_only", "review_read_only", "memory_read"], "maximumContextTokens": 24000, "requiresProvenance": true },
      "memory": { "namespace": "s-loom/innovation/baseline-analyst", "priorityFields": ["evidence", "finding", "recommendation"], "evidenceLimit": 12, "riskLimit": 5, "maxFieldChars": 2600, "ttlSeconds": 1800, "negativeEdgeOnFailure": false, "personaPartitioned": true }
    },
    {
      "id": "option-generator", "title": "orthogonal option generator", "mission": "Produce materially different candidate approaches grounded in available primitives.", "evidenceContract": ["candidate", "novel mechanism", "cost"],
      "persona": { "defaultPersona": "tailwright-prompt-architect", "compatibleRoles": ["mutator", "synthesist", "architect"], "allowedPermissionClasses": ["design_read_only", "memory_read"], "maximumContextTokens": 24000, "requiresProvenance": true },
      "memory": { "namespace": "s-loom/innovation/option-generator", "priorityFields": ["recommendation", "finding", "risks"], "evidenceLimit": 6, "riskLimit": 8, "maxFieldChars": 2800, "ttlSeconds": 1200, "negativeEdgeOnFailure": false, "personaPartitioned": true }
    },
    {
      "id": "option-falsifier", "title": "adversarial option falsifier", "mission": "Attempt to disprove candidates and identify the smallest informative experiment.", "evidenceContract": ["falsification condition", "experiment", "selection risk"],
      "persona": { "defaultPersona": "chaos-refuter", "compatibleRoles": ["prosecutor", "judge"], "allowedPermissionClasses": ["review_read_only"], "maximumContextTokens": 24000, "requiresProvenance": true },
      "memory": { "namespace": "s-loom/innovation/option-falsifier", "priorityFields": ["risks", "evidence", "recommendation"], "evidenceLimit": 8, "riskLimit": 10, "maxFieldChars": 2400, "ttlSeconds": 1200, "negativeEdgeOnFailure": false, "personaPartitioned": true }
    }
  ]
}
